# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/
venv/
env/

# YOLO pose model weights (auto-downloaded on first run, ~113MB / ~6MB)
*.pt

# Analyzer outputs
out_*/
*/stills/

# User footage (kept local — never pushed). Ignore EVERYTHING the rider drops in
# videos/ (clips AND photos), keeping only the tracked README guide.
videos/*
!videos/README.md
# Also ignore stray video files anywhere else in the tree (but keep demo clips in files/).
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.jpeg
*.jpg
*.heic
!files/**/*.mp4
!files/**/*.jpg
!files/**/*.jpeg

# Personal rider specs (kept local). The rider.example.yaml template is kept.
rider.yaml
rider.*.yaml
!rider.example.yaml

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
